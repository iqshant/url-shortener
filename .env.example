# These are already set inside docker-compose.yml for local use.
# This file documents what's tunable if you deploy instances manually
# (e.g. on separate VMs/containers outside docker-compose).

PORT=3000

# Must be unique per running instance, 0-1023. Two instances sharing a
# WORKER_ID can generate colliding short codes.
WORKER_ID=0

PGHOST=postgres
PGPORT=5432
PGUSER=shortener
PGPASSWORD=shortener
PGDATABASE=shortener

REDIS_URL=redis://redis:6379

# Used to build the shortUrl returned to clients (e.g. https://short.example.com)
PUBLIC_BASE_URL=http://localhost:8080
